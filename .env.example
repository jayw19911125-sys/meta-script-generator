# ========== Meta 腳本生成器 環境變數範例 ==========
# 複製為 .env 並依環境填入。以下「基礎設施 ID」若未設定，
# 程式會自動採用此處列出的預設值（見 server/_core/env.ts），行為不變。

# ---------- 核心 ----------
VITE_APP_ID=
JWT_SECRET=
DATABASE_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ---------- LLM（Forge API）----------
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=

# ---------- Slack 通知 ----------
# #影音製作 頻道
SLACK_CHANNEL_ID=C0AUR4QJ07Q

# ---------- Monday.com ----------
# 客戶看板
MONDAY_BOARD_ID=5027852889
# 「現況」欄位 ID
MONDAY_STATUS_COLUMN_ID=color_mm2gg7qh
# 「腳本確認中」標籤 ID
MONDAY_STATUS_LABEL_ID=12

# ---------- Notion 頁面 ID ----------
# B2 客戶腳本庫（notion-create-pages 的 parent.page_id，需帶連字號格式）
NOTION_B2_SCRIPT_LIBRARY_PAGE_ID=37b97a06-fae5-818c-91d1-c2bd91baa373
# L 系列：漏斗廣告腳本框架
NOTION_PAGE_ID_L01=37997a06-fae5-81d6-9837-c8b6c1dd242d
NOTION_PAGE_ID_L02=37997a06-fae5-8109-801f-d3835ed6fa6e
NOTION_PAGE_ID_L03=37997a06-fae5-8191-9536-e1f3aff7c48e
# A3：108 筆開頭鉤子庫數據分析
NOTION_PAGE_ID_A3_HOOK_DATA=37997a06-fae5-815d-b375-ef4353b4d362
# H 系列：爆款方法論知識庫
NOTION_PAGE_ID_H_METHODOLOGY=37b97a06-fae5-819e-b37a-f3f13be3f8c4
